      "id": "gc-004",
      "name": "Fetch T1 Customers",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [660, 60]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst items = data.data?.items || [];\nconst txt = (v) => {\n  if (!v) return '';\n  if (typeof v === 'string') return v;\n  if (Array.isArray(v)) { const f = v[0]; if (!f) return ''; if (typeof f === 'string') return f; return f.text || f.name || ''; }\n  if (v.value && Array.isArray(v.value)) { const f = v.value[0]; if (!f) return ''; if (typeof f === 'string') return f; return f.text || f.name || ''; }\n  return '';\n};\nconst customers = items.map(it => ({\n  record_id: it.record_id,\n  shop_name: txt(it.fields['Shop Name']),\n  line_id:   txt(it.fields['LINE User ID']) || txt(it.fields['C.LINE User ID']) || '',\n  phone:     txt(it.fields['Phone']) || ''\n})).filter(c => c.shop_name).sort((a,b) => a.shop_name.localeCompare(b.shop_name, 'th'));\nreturn [{ json: { customers } }];"
      },
      "id": "gc-005",
      "name": "Format Customers",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 60]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, customers: $json.customers }) }}",
        "options": { "responseHeaders": { "entries": [{ "name": "Access-Control-Allow-Origin", "value": "*" }] } }
      },
