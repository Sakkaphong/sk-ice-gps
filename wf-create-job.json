    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst items = data.data?.items || [];\nconst txt = (v) => {\n  if (!v) return '';\n  if (typeof v === 'string') return v;\n  if (Array.isArray(v)) { const f = v[0]; if (!f) return ''; if (typeof f === 'string') return f; return f.text || f.name || ''; }\n  if (v.value && Array.isArray(v.value)) { const f = v.value[0]; if (!f) return ''; if (typeof f === 'string') return f; return f.text || f.name || ''; }\n  return '';\n};\nconst techs = items.map(it => ({\n  record_id: it.record_id,\n  name:       txt(it.fields['Name']),\n  role:       txt(it.fields['Role']) || '',\n  line_id:    txt(it.fields['LINE User ID']) || txt(it.fields['tech_line_id']) || '',\n  phone:      txt(it.fields['Phone']) || ''\n})).filter(t => t.name).sort((a,b) => a.name.localeCompare(b.name, 'th'));\nreturn [{ json: { techs } }];"
