    {
      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────\n// Extract Event\n// จัดการทั้ง 'message' และ 'postback' (ack จากปุ่ม ✅ ตอบแล้ว)\n// ─────────────────────────────────────────────\nconst body   = $json.body || $json;\nconst events = body.events || [];\nconst event  = events[0];\n\nif (!event) return [];\n\n// ── Postback: SK TEAM กด ✅ ตอบแล้ว ──\nif (event.type === 'postback') {\n  const postData = event.postback?.data || '';\n  const params   = Object.fromEntries(new URLSearchParams(postData));\n  if (params.action === 'ack' && params.row_id) {\n    return [{ json: {\n      eventType:  'postback_ack',\n      rowId:      params.row_id,\n      userId:     event.source?.userId  || '',\n      groupId:    event.source?.groupId || '',\n      replyToken: event.replyToken      || ''\n    }}];\n  }\n  return [];\n}\n\n// ── Message ──\nif (event.type !== 'message') return [];\n\nconst source      = event.source || {};\nconst sourceType  = source.type || 'user';\nconst userId      = source.userId  || '';\nconst groupId     = source.groupId || source.roomId || '';\nconst replyToken  = event.replyToken || '';\nconst messageText = event.message?.text || '';\nconst messageType = event.message?.type || 'unknown';\n\nif (messageType !== 'text' || !userId) return [];\n\n// กลุ่มภายใน SK-ICE — หยุดทันที ไม่ผ่านไป After Hours ไม่ log\nconst INTERNAL_GROUPS = [\n  'C40b37d81f4e199a7b7357537166a1efd'  // SK TEAM (11)\n];\nif (sourceType === 'group' && INTERNAL_GROUPS.includes(groupId)) return [];\n\nreturn [{ json: {\n  eventType: 'message',\n  userId, groupId, sourceType, replyToken,\n  combinedMessage: messageText, messageType\n} }];"
      },
      "id": "6aa99820-f29e-4935-b956-77c689fc7f12",
      "name": "Extract Message",
      "type": "n8n-nodes-base.code",
      "position": [0, 240],
      "typeVersion": 2
    },

