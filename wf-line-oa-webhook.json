    {
      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────\n// Build Notification Data\n// รวม LINE profile + source info + message\n// เพื่อให้ nodes ถัดไปใช้ $json.xxx ได้เลย\n// ─────────────────────────────────────────────\nconst profile = $input.first().json;\nconst msgData = $('Extract Message').first().json;\nconst sourceType = msgData.sourceType || 'user';\nconst groupId    = msgData.groupId    || '';\n\nlet groupName   = '';\nlet sourceLabel = '💬 DM ส่วนตัว';\n\nif (sourceType === 'group') {\n  try {\n    const grp = $('Get Group Name').first().json;\n    groupName = grp.groupName || '';\n    sourceLabel = groupName\n      ? ('📢 กลุ่ม: ' + groupName)\n      : ('📢 กลุ่ม (ID: ' + groupId + ')');\n  } catch(e) {\n    sourceLabel = '📢 กลุ่ม (ID: ' + groupId + ')';\n  }\n} else if (sourceType === 'room') {\n  sourceLabel = '💬 ห้องกลุ่ม';\n}\n\nreturn [{ json: {\n  userId:          msgData.userId,\n  groupId:         groupId,\n  sourceType:      sourceType,\n  sourceLabel:     sourceLabel,\n  groupName:       groupName,\n  combinedMessage: msgData.combinedMessage,\n  replyToken:      msgData.replyToken,\n  displayName:     profile.displayName || 'ไม่ทราบชื่อ',\n  pictureUrl:      profile.pictureUrl  || ''\n}}];"
      },
      "id": "new-build-notif-001",
      "name": "Build Notification Data",
      "type": "n8n-nodes-base.code",
      "position": [960, 240],
      "typeVersion": 2
    },

